# Copia este archivo a ".env" y rellena las claves si quieres la capa OPCIONAL
# de estadísticas detalladas (tiros, corners, tarjetas, posesión, lesiones).
#
# El proyecto FUNCIONA SIN ESTO: el modelo principal de goles usa solo el dataset
# público gratuito. Estas claves solo enriquecen mercados secundarios.

# API-Football (https://www.api-football.com/) — tier gratis: 100 peticiones/día.
API_FOOTBALL_KEY=

# football-data.org (https://www.football-data.org/) — tier gratis.
FOOTBALL_DATA_KEY=
